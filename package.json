{
  "name": "skiplist-visualizer",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for a skip list visualizer backend and frontend placeholder",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspace backend",
    "start:dev": "npm run start:dev --workspace backend",
    "lint": "npm run lint --workspace backend",
    "test": "npm test --workspace backend",
    "test:e2e": "npm run test:e2e --workspace backend",
    "format": "npm run format --workspace backend"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
